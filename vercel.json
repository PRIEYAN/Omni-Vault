{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/server" }
  ],
  "functions": {
    "api/server.js": {
      "maxDuration": 30
    }
  }
}
